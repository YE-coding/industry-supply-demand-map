{
  "name": "industry-cycle-skill-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "reports:audit-sources": "node scripts/auditReportSources.mjs",
    "reports:validate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validateAllReports.ps1",
    "report:advanced-packaging": "node scripts/upgradeReports.mjs --report 18_先进封装行业供需周期分析.md",
    "validate:advanced-packaging": "python .skill-staging/industry-cycle-analysis/scripts/validate_report.py 18_先进封装行业供需周期分析.md --mode full --strict",
    "extract": "node scripts/extractCases.mjs",
    "predev": "npm run extract",
    "dev": "vite --host 127.0.0.1",
    "prebuild": "npm run extract",
    "build": "vite build",
    "serve": "vite preview --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "deploy": "npm run build && gh-pages -d dist -t"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "mermaid": "^11.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
